# ── Turkiy Korpus — muhit o'zgaruvchilari namunasi ──────────────
# Nusxa oling:  cp .env.example .env   (va qiymatlarni to'ldiring)
# .env fayli git'ga YUKLANMAYDI (.gitignore'da).

# Django
DJANGO_SECRET_KEY=bu-yerga-uzun-tasodifiy-maxfiy-kalit
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com www.example.com

# Ma'lumotlar bazasi (SQLite uchun: USE_POSTGRES=False)
USE_POSTGRES=True
DB_NAME=turkiy_korpus
DB_USER=turkiy_user
DB_PASSWORD=parol
DB_HOST=localhost
DB_PORT=5432

# CORS (React dev server / frontend domeni)
CORS_ALLOWED_ORIGINS=https://example.com

# Email (taklif xabarlari uchun)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Turkiy Korpus <noreply@example.com>
ADMIN_EMAIL=admin@example.com
